# Village Elder NPC

proc greeting():
    say("Elder", "Welcome, traveler.")
    say("Elder", "Our village has been troubled by slimes lately.")
    say("Elder", "If you could help us, we would be grateful.")

proc quest():
    say("Elder", "The slimes come from the forest to the east.")
    say("Elder", "Be careful out there.")
    say("Hero", "We'll handle it.")
